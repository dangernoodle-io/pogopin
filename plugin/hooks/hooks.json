{
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/self-heal.js" } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "${CLAUDE_PLUGIN_DATA}/bin/pogo claude hooks user-prompt-submit" } ] }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_pogopin-mcp_pogopin__.*",
        "hooks": [ { "type": "command", "command": "${CLAUDE_PLUGIN_DATA}/bin/pogo claude hooks pre-tool-use" } ]
      }
    ]
  }
}
